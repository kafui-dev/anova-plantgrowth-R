# Question 7 - Bootstrap de la mÃĐdiane avec B=100 en utilisant la library boot
# Chargement de la library boot
library(boot)
# DonnÃĐes des accidents d'avions
accidents <- c(23,16,21,24,34,30,28,24,26,18,23,23,36,37,49,50,5,56,46,41,54,30,40,31)
# DÃĐfinition de la fonction statistique pour la mÃĐdiane
fonction_mediane <- function(data, indices) {
return(median(data[indices]))
}
# ParamÃĻtres
set.seed(1)  # Pour la reproductibilitÃĐ
B <- 100     # Nombre d'ÃĐchantillons bootstrap
# Calcul bootstrap de la mÃĐdiane
boot_resultats <- boot(accidents, fonction_mediane, R = B)
# Affichage des rÃĐsultats
cat("7 - Bootstrap de la mÃĐdiane avec library boot (B = 100) :\n")
print(boot_resultats)
# Statistiques supplÃĐmentaires
cat("\nStatistiques dÃĐtaillÃĐes :\n")
cat("Estimation bootstrap de la mÃĐdiane :", mean(boot_resultats$t), "\n")
cat("Erreur standard bootstrap :", sd(boot_resultats$t), "\n")
cat("MÃĐdiane originale :", median(accidents), "\n")
cat("Biais estimÃĐ :", boot_resultats$t0 - mean(boot_resultats$t), "\n")
# Optionnel : Intervalle de confiance bootstrap
cat("\nIntervalle de confiance bootstrap (percentile) :\n")
print(boot.ci(boot_resultats, type = "perc"))
# Suite : Calcul des intervalles de confiance bootstrap pour la mÃĐdiane
# Calcul des diffÃĐrents intervalles de confiance bootstrap
ic_percentile <- boot.ci(boot_resultats, type = "perc")
ic_normal <- boot.ci(boot_resultats, type = "norm")
ic_basic <- boot.ci(boot_resultats, type = "basic")
ic_bca <- boot.ci(boot_resultats, type = "bca")
# Affichage des rÃĐsultats
cat("\nIntervalles de confiance bootstrap pour la mÃĐdiane (B = 100) :\n")
cat("\n1. Intervalle percentile :\n")
cat("  [", ic_percentile$percent[4], ", ", ic_percentile$percent[5], "]\n", sep = "")
cat("\n2. Intervalle normal (basÃĐ sur la normale) :\n")
cat("  [", ic_normal$normal[2], ", ", ic_normal$normal[3], "]\n", sep = "")
cat("\n3. Intervalle basic :\n")
cat("  [", ic_basic$basic[4], ", ", ic_basic$basic[5], "]\n", sep = "")
cat("\n4. Intervalle BCa (Bias-Corrected and Accelerated) :\n")
cat("  [", ic_bca$bca[4], ", ", ic_bca$bca[5], "]\n", sep = "")
# RÃĐsumÃĐ dans un data.frame pour plus de clartÃĐ
resultats_ic <- data.frame(
MÃĐthode = c("Percentile", "Normal", "Basic", "BCa"),
Borne_inf = c(ic_percentile$percent[4], ic_normal$normal[2], ic_basic$basic[4], ic_bca$bca[4]),
Borne_sup = c(ic_percentile$percent[5], ic_normal$normal[3], ic_basic$basic[5], ic_bca$bca[5]),
Largeur = c(ic_percentile$percent[5] - ic_percentile$percent[4],
ic_normal$normal[3] - ic_normal$normal[2],
ic_basic$basic[5] - ic_basic$basic[4],
ic_bca$bca[5] - ic_bca$bca[4])
)
cat("\n\nRÃĐcapitulatif des intervalles de confiance :\n")
print(resultats_ic)
# Visualisation des rÃĐsultats
cat("\nMÃĐdiane originale :", median(accidents), "\n")
cat("Estimation bootstrap de la mÃĐdiane :", mean(boot_resultats$t), "\n")
ic_normal

# CrÃĐer le graphique
ggplot(tukey_df, aes(x = diff, y = comparaison)) +
geom_point(size = 3, color = "darkblue") +
geom_errorbarh(aes(xmin = lwr, xmax = upr),
height = 0.2, color = "darkblue", size = 1) +
geom_vline(xintercept = 0, linetype = "dashed", color = "red", size = 1) +
labs(title = "Test de comparaisons multiples de Tukey",
subtitle = "DiffÃĐrences des moyennes avec IC Ã  95%",
x = "DiffÃĐrence des moyennes",
y = "Comparaisons",
caption = "Les intervalles qui ne croisent pas 0 sont significatifs") +

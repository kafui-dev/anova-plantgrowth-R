set.seed(123)  # Pour la reproductibilitÃĐ
M <- 50000
n <- 20
mu <- -1.2
sigma <- sqrt(2)
echantillons <- matrix(rnorm(M*n, mean=mu, sd=sigma), nrow=M, ncol=n, byrow=TRUE)
echantillons
echantillons[1]
echantillons[1][1]
echantillons[1][1][1]
echantillons.shape
echantillons.type
shape(echantillons)
alpha <- 0.10
moyennes <- apply(echantillons, 1, mean)
ecarts <- apply(echantillons, 1, sd)
t_critique <- qt(1 - alpha/2, df=n-1)
bornes_inf <- moyennes - t_critique * ecarts / sqrt(n)
bornes_sup <- moyennes + t_critique * ecarts / sqrt(n)
couverture <- mean((bornes_inf <= mu) & (mu <= bornes_sup))
couverture  # Doit ÃŠtre proche de 90%

library(boot)
boot_percentile_CI <- function(ech, B=1000, alpha=0.10) {
n <- length(ech)
boot_means <- replicate(B, mean(sample(ech, n, replace=TRUE)))
quantile(boot_means, probs=c(alpha/2, 1-alpha/2))
}
boot_percentile_CI <- function(ech, B=1000, alpha=0.10) {
n <- length(ech)
boot_means <- replicate(B, mean(sample(ech, n, replace=TRUE)))
quantile(boot_means, probs=c(alpha/2, 1-alpha/2))
}
intervals <- t(apply(echantillons_exp, 1, boot_percentile_CI, B=1000, alpha=0.10))
couverture_boot <- mean(intervals[,1] <= 10 & intervals[,2] >= 10)
couverture_boot

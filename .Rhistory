# Chargement des packages Ã  utiliser
library(dplyr)
library(ggplot2)
# Chargement des donnÃĐes
data(PlantGrowth)
head(PlantGrowth)
str(PlantGrowth)
summary(PlantGrowth)
p = ggplot(data = PlantGrowth)
p + geom_boxplot(aes(x=group, y=weight, fill=group), alpha = 0.7) +
scale_fill_manual(values = c("ctrl" = "#69b3a2",
"trt1" = "#ff9f4b",
"trt2" = "#ed7d7d")) +
geom_jitter(aes(x=group, y=weight)) +
ggtitle("Weight of plants per group")
ggsave("boxplot.png")
p + geom_boxplot(aes(x=group, y=weight, fill=group), alpha = 0.7) +
scale_fill_manual(values = c("ctrl" = "#69b3a2",
"trt1" = "#ff9f4b",
"trt2" = "#ed7d7d")) +
geom_jitter(aes(x=group, y=weight)) +
ggtitle("Weight of plants per group")
anova = aov(weight~group, data=PlantGrowth)
summary(anova)
r = residuals(anova)
shapiro.test(r)
bartlett.test(r)
bartlett.test(weight~group, data=PlantGrowth)
tkr = TukeyHSD(anova)
tkr
